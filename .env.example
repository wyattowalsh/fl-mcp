# FL-MCP Configuration
# All variables are prefixed with FL_MCP_ and map to Settings fields
# in src/fl_mcp/config/settings.py.
# Uncomment and edit any line to override the default value.

# Human-readable runtime name
# FL_MCP_APP_NAME=fl-mcp

# Console log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# FL_MCP_LOG_LEVEL=INFO

# Optional auth token for guarded execution
# FL_MCP_AUTH_TOKEN=your-secret-token-here

# Host bound by the streamable HTTP transport
# FL_MCP_HTTP_HOST=127.0.0.1

# Port bound by the streamable HTTP transport (1-65535)
# FL_MCP_HTTP_PORT=8765

# Database connection URL
# FL_MCP_DATABASE_URL=sqlite:///fl_mcp.db
