{
  "$defs": {
    "ProviderCapability": {
      "additionalProperties": false,
      "properties": {
        "description": {"type": "string"},
        "name": {"type": "string"}
      },
      "required": ["name", "description"],
      "type": "object"
    },
    "ProviderOperation": {
      "additionalProperties": false,
      "properties": {
        "idempotent": {"type": "boolean"},
        "operation": {"type": "string"},
        "rollback_classification": {
          "enum": [
            "fully_transactional",
            "checkpointed",
            "best_effort",
            "unsafe_raw"
          ],
          "type": "string"
        }
      },
      "required": ["operation", "rollback_classification", "idempotent"],
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "capabilities": {"items": {"$ref": "#/$defs/ProviderCapability"}, "type": "array"},
    "operations": {"items": {"$ref": "#/$defs/ProviderOperation"}, "type": "array"},
    "provider_name": {"type": "string"},
    "version": {"type": "string"}
  },
  "required": ["provider_name", "version"],
  "title": "ProviderManifest",
  "type": "object"
}
